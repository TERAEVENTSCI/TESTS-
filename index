  changeStage(id,newStage){
    const d=S.deals.find(x=>x.id===id);if(!d)return;
    d.stage=parseInt(newStage);d.updatedAt=new Date().toISOString();
    addAudit('Changement étape', d.ref+' → '+getStageName(newStage));
    save(); App.refreshAll();
  }
};

