const Auth = {
  login(){
    const u=document.getElementById('login-user').value.trim();
    const p=document.getElementById('login-pass').value;
    const errEl=document.getElementById('login-error');
    if(!u||!p){errEl.style.display='block';return}
    const user=S.users.find(x=>x.login===u && x.pass===hashPassword(p));
    if(user){
      if(user.active===false){errEl.innerHTML='<i class="fas fa-ban"></i> Compte désactivé. Contactez l\'administrateur.';errEl.style.display='block';return}
      currentUser=user;
      document.getElementById('login-screen').style.display='none';
      document.getElementById('sidebar-uname').textContent=user.name;
      document.getElementById('sidebar-urole').textContent=user.role;
      document.getElementById('sidebar-avatar').textContent=user.name.charAt(0).toUpperCase();
      addAudit('Connexion','Utilisateur: '+user.name);save();
      if(user.role==='Commercial'){document.querySelector('[data-view="admin"]').parentElement.style.display='none';}
      if(user.role==='Lecture seule'){
        document.querySelector('[data-view="admin"]').parentElement.style.display='none';
        document.querySelectorAll('.btn-primary').forEach(b=>{if(b.textContent.includes('Nouvelle'))b.style.display='none'});
      }
      App.init();
    } else {
      errEl.style.display='block';
    }
  },
  logout(){
    addAudit('Déconnexion');save();
    currentUser=null;location.reload();
  }
};

