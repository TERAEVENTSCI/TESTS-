/* ═══════════════════════════════════════════════
   COMMISSIONS  —  calcul par objectif individuel
   ═══════════════════════════════════════════════ */
const Commissions = {
  calculate(){
    const period=getPeriod();
    const commercials=S.users.filter(u=>u.role!=='Lecture seule'&&u.active!==false);
    let totalComm=0, totalCA=0, totalBonus=0;

    const rows=commercials.map(u=>{
      /* Objectif individuel de l'utilisateur */
      const targetUser = getUserTarget(u);

      /* Affaires gagnées pour cet utilisateur sur la période */
      const wonDeals=S.deals.filter(d=>d.stage===5 && d.userId===u.id && (period==='ALL'||(d.date||'').startsWith(period)));
      const ca=wonDeals.reduce((a,b)=>a+b.amount,0);

      /* Taux d'atteinte de l'objectif individuel */
      const atteinte=targetUser>0?Math.round((ca/targetUser)*100):0;

      /* Taux de commission : individuel (fiche user) ou paliers */
      let rate = u.rate || 0;
      if(S.settings.commMode==='tiered' && S.settings.tiers){
        const tier=S.settings.tiers.find(t=>ca>=t.min&&ca<(t.max===Infinity?Number.MAX_SAFE_INTEGER:t.max));
        if(tier) rate=tier.rate;
      }

      /* Commission de base */
      const commission=Math.round(ca*rate/100);

      /* Bonus dépassement objectif */
      const bonus=atteinte>100 ? Math.round((ca-targetUser)*(S.settings.bonusRate||0)/100) : 0;

      const total=commission+bonus;
      totalComm+=total; totalCA+=ca; totalBonus+=bonus;

      const commKey=period+'_'+u.id;
      const status=(S.commissions||{})[commKey]||'Attente';
      return {user:u, ca, targetUser, atteinte, rate, commission, bonus, total, status, commKey};
    });

    return {rows, totalComm, totalCA, totalBonus};
  },

  render(){
    const {rows, totalComm, totalCA, totalBonus}=this.calculate();
    document.getElementById('comm-summary').innerHTML=`
      <div class="cs-card"><div class="cs-label">CA total gagné</div><div class="cs-value" style="color:var(--success)">${fmtCur(totalCA)}</div></div>
      <div class="cs-card"><div class="cs-label">Commissions totales</div><div class="cs-value" style="color:var(--primary)">${fmtCur(totalComm)}</div></div>
      <div class="cs-card"><div class="cs-label">Bonus distribués</div><div class="cs-value" style="color:var(--warning)">${fmtCur(totalBonus)}</div></div>`;

    const statusBadge={'Attente':'badge-attente','Validée':'badge-validee','Payée':'badge-payee'};
    const tbody=document.querySelector('#tbl-commissions tbody');
    tbody.innerHTML=rows.map(r=>`<tr>
      <td>
        <strong>${r.user.name}</strong>
        <div style="font-size:.7rem;color:var(--text-muted)">${r.user.role}</div>
      </td>
      <td><strong style="color:var(--success)">${fmtCur(r.ca)}</strong></td>
      <td>
        <strong>${fmtCur(r.targetUser)}</strong>
        ${r.user.target&&r.user.target>0
          ? '<div style="font-size:.68rem;color:var(--primary)"><i class="fas fa-user" style="font-size:.6rem"></i> individuel</div>'
          : '<div style="font-size:.68rem;color:var(--text-muted)"><i class="fas fa-users" style="font-size:.6rem"></i> global ÷ équipe</div>'}
      </td>
      <td>
        <div style="display:flex;align-items:center;gap:.5rem">
          <div class="progress" style="width:80px"><div class="progress-bar" style="width:${Math.min(100,r.atteinte)}%;background:${r.atteinte>=100?'var(--success)':r.atteinte>=50?'var(--primary)':'var(--danger)'}"></div></div>
          <strong style="color:${r.atteinte>=100?'var(--success)':r.atteinte>=50?'var(--primary)':'var(--danger)'}">${r.atteinte}%</strong>
        </div>
      </td>
      <td><strong>${r.rate}%</strong></td>
      <td>${fmtCur(r.commission)}</td>
      <td>${r.bonus>0?`<strong style="color:var(--warning)">${fmtCur(r.bonus)}</strong>`:'—'}</td>
      <td><strong style="color:var(--primary)">${fmtCur(r.total)}</strong></td>
      <td><span class="badge ${statusBadge[r.status]||'badge-attente'}">${r.status}</span></td>
      <td>
        ${currentUser?.role==='Super Admin'||currentUser?.role==='Manager'?`
        <select class="form-control" style="width:auto;padding:.2rem .4rem;font-size:.72rem;margin:0" onchange="Commissions.setStatus('${r.commKey}',this.value)">
          <option value="Attente" ${r.status==='Attente'?'selected':''}>En attente</option>
          <option value="Validée" ${r.status==='Validée'?'selected':''}>Validée</option>
          <option value="Payée" ${r.status==='Payée'?'selected':''}>Payée</option>
        </select>`:'—'}
      </td>
    </tr>`).join('');
  },

  setStatus(key, status){
    if(!S.commissions)S.commissions={};
    S.commissions[key]=status;
    addAudit('Changement statut commission', key+' → '+status);
    save(); this.render(); Toast.show('Statut commission mis à jour');
  }
};

