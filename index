  },

  /* Affiche / masque le champ de création automatique */
  onContactChange(){
    const val = document.getElementById('deal-contact').value;
    const nameInput = document.getElementById('deal-new-contact-name');
    const hint = document.getElementById('new-contact-hint');
    if(val === '__new__'){
      nameInput.style.display = 'block';
      nameInput.focus();
    } else {
      nameInput.style.display = 'none';
      hint.style.display = 'none';
    }
  },

  onNewContactNameInput(){
    const val = document.getElementById('deal-new-contact-name').value.trim();
    document.getElementById('new-contact-hint').style.display = val ? 'block' : 'none';
  },

  save(){
    const id=document.getElementById('deal-id').value;
    const name=document.getElementById('deal-name').value.trim();
    const amount=parseFloat(document.getElementById('deal-amount').value);
    if(!name){Toast.show('Le nom de l\'affaire est obligatoire','error');return}
    if(!amount||amount<=0){Toast.show('Le montant est obligatoire','error');return}
    const stage=parseInt(document.getElementById('deal-stage').value);
    if(stage===6 && !document.getElementById('deal-loss-reason').value.trim()){Toast.show('Le motif de perte est obligatoire','error');return}

    /* ─── Gestion contact : création automatique si "__new__" ─── */
    let contactId = parseInt(document.getElementById('deal-contact').value) || null;
    const contactSelectVal = document.getElementById('deal-contact').value;
    if(contactSelectVal === '__new__'){
      const newName = document.getElementById('deal-new-contact-name').value.trim();
      if(!newName){Toast.show('Veuillez saisir le nom du nouveau client','error');return}
      // Vérifier si un contact avec ce nom existe déjà (évite les doublons)
      const existing = S.contacts.find(c => c.name.toLowerCase() === newName.toLowerCase());
      if(existing){
        contactId = existing.id;
        Toast.show('Contact existant retrouvé : '+existing.name,'info');
      } else {
        const newContact = {
          id: Date.now(),
          name: newName,
          type: 'Prospect',
          sector: '',
          person: document.getElementById('deal-interlocuteur').value.trim() || '',
          phone: '',
          email: '',
          address: '',
          userId: parseInt(document.getElementById('deal-user').value) || currentUser?.id || null,
          notes: 'Créé automatiquement lors de l\'affaire : '+name,
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString()
        };
        S.contacts.push(newContact);
        contactId = newContact.id;
        addAudit('Création contact automatique', newName+' (via affaire '+name+')');
        Toast.show('✅ Contact "'+newName+'" créé automatiquement dans la base');
      }
    }

    const data={
      name, amount, stage, contactId,
      interlocuteur:document.getElementById('deal-interlocuteur').value.trim(),
      userId:parseInt(document.getElementById('deal-user').value)||currentUser?.id||1,
      source:document.getElementById('deal-source').value,
      date:document.getElementById('deal-date').value,
      closeDate:document.getElementById('deal-close-date').value,
      nextAction:document.getElementById('deal-next-action').value.trim(),
      lossReason:document.getElementById('deal-loss-reason').value.trim(),
      notes:document.getElementById('deal-notes').value.trim()
    };

    if(id){
      const idx=S.deals.findIndex(d=>d.id==id);
      S.deals[idx]={...S.deals[idx],...data,updatedAt:new Date().toISOString()};
      addAudit('Modification affaire', name+' – '+fmtCur(amount));
      Toast.show('Affaire mise à jour');
    } else {
      data.id=Date.now();
      data.ref='AF-'+String(S.deals.length+1).padStart(4,'0');
      data.createdAt=new Date().toISOString();
      data.updatedAt=data.createdAt;
      S.deals.push(data);
      addAudit('Création affaire', data.ref+' – '+name);
      Toast.show('Affaire créée avec succès');
    }
    save(); Modal.close('modal-deal'); App.refreshAll();
  },

  delete(id){
    const d=S.deals.find(x=>x.id===id);
    if(!d||!confirm('Supprimer définitivement l\'affaire '+d.ref+' ?'))return;
    S.deals=S.deals.filter(x=>x.id!==id);
    addAudit('Suppression affaire', d.ref+' – '+d.name);
    save(); App.refreshAll(); Toast.show('Affaire supprimée');
