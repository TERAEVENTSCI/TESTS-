  _exportPDF(element, filename){
    html2pdf().set({margin:[10,10,10,10],filename:filename+'.pdf',html2canvas:{scale:2,useCORS:true},jsPDF:{format:'a4',orientation:'landscape'}}).from(element).save();
    Toast.show('Export PDF en cours...');
  },
  exportDashboard(){
    const div=document.createElement('div');
    div.style.cssText='padding:1.5rem;font-family:Plus Jakarta Sans,sans-serif;font-size:12px;color:#1e293b';
    const deals=filterByPeriod(S.deals);
    const realized=deals.filter(d=>d.stage===5).reduce((a,b)=>a+b.amount,0);
    const weighted=deals.filter(d=>d.stage<5).reduce((a,b)=>a+(b.amount*getStageProb(b.stage)/100),0);
    const activeDeals=deals.filter(d=>d.stage<6);
    div.innerHTML=this._generateHeader()+`
      <h3 style="margin-bottom:1rem">Rapport d'activité commerciale</h3>
      <table style="width:100%;margin-bottom:1rem;font-size:11px"><tr>
        <td style="padding:.5rem;background:#f1f5f9;border-radius:6px;text-align:center"><strong>CA Réalisé</strong><br><span style="font-size:1.1rem;font-weight:800;color:#059669">${fmtCur(realized)}</span></td>
        <td style="padding:.5rem;background:#f1f5f9;border-radius:6px;text-align:center"><strong>Pipeline pondéré</strong><br><span style="font-size:1.1rem;font-weight:800;color:#2563eb">${fmtCur(Math.round(weighted))}</span></td>
        <td style="padding:.5rem;background:#f1f5f9;border-radius:6px;text-align:center"><strong>Affaires actives</strong><br><span style="font-size:1.1rem;font-weight:800">${activeDeals.length}</span></td>
      </tr></table>
      <table style="width:100%;border-collapse:collapse;font-size:10px">
        <thead><tr style="background:#0f172a;color:white"><th style="padding:6px;text-align:left">Réf.</th><th style="padding:6px;text-align:left">Affaire</th><th style="padding:6px;text-align:left">Client</th><th style="padding:6px;text-align:left">Interlocuteur</th><th style="padding:6px;text-align:left">Montant</th><th style="padding:6px;text-align:left">Étape</th><th style="padding:6px;text-align:left">Commercial</th></tr></thead>
        <tbody>${activeDeals.map((d,i)=>{const c=getContact(d.contactId);const u=getUser(d.userId);return`<tr style="background:${i%2?'#f8fafc':'white'}"><td style="padding:5px">${d.ref||''}</td><td style="padding:5px">${d.name}</td><td style="padding:5px">${c?c.name:'—'}</td><td style="padding:5px">${d.interlocuteur||'—'}</td><td style="padding:5px;font-weight:700">${fmtCur(d.amount)}</td><td style="padding:5px">${getStageName(d.stage)}</td><td style="padding:5px">${u?u.name:'—'}</td></tr>`}).join('')}</tbody>
      </table>`;
    this._exportPDF(div, 'Rapport_Activite_'+S.settings.company);
  },
  exportCommissions(){
    const div=document.createElement('div');
    div.style.cssText='padding:1.5rem;font-family:Plus Jakarta Sans,sans-serif;font-size:12px;color:#1e293b';
    const {rows,totalComm,totalCA}=Commissions.calculate();
    div.innerHTML=this._generateHeader()+`
      <h3 style="margin-bottom:1rem">Rapport de Commissions — Objectifs individuels</h3>
      <table style="width:100%;border-collapse:collapse;font-size:10px">
        <thead><tr style="background:#0f172a;color:white">
          <th style="padding:6px;text-align:left">Commercial</th>
          <th style="padding:6px;text-align:left">CA Réalisé</th>
          <th style="padding:6px;text-align:left">Objectif individuel</th>
          <th style="padding:6px;text-align:left">Atteinte</th>
          <th style="padding:6px;text-align:left">Taux comm.</th>
          <th style="padding:6px;text-align:left">Commission</th>
          <th style="padding:6px;text-align:left">Bonus</th>
          <th style="padding:6px;text-align:left">Total</th>
          <th style="padding:6px;text-align:left">Statut</th>
        </tr></thead>
        <tbody>${rows.map((r,i)=>`<tr style="background:${i%2?'#f8fafc':'white'}">
          <td style="padding:5px;font-weight:700">${r.user.name}</td>
          <td style="padding:5px">${fmtCur(r.ca)}</td>
          <td style="padding:5px">${fmtCur(r.targetUser)}</td>
          <td style="padding:5px">${r.atteinte}%</td>
          <td style="padding:5px">${r.rate}%</td>
          <td style="padding:5px">${fmtCur(r.commission)}</td>
          <td style="padding:5px">${r.bonus>0?fmtCur(r.bonus):'—'}</td>
          <td style="padding:5px;font-weight:700">${fmtCur(r.total)}</td>
          <td style="padding:5px">${r.status}</td>
        </tr>`).join('')}
        <tr style="background:#0f172a;color:white;font-weight:700">
          <td style="padding:6px">TOTAL</td>
          <td style="padding:6px">${fmtCur(totalCA)}</td>
          <td style="padding:6px" colspan="5"></td>
          <td style="padding:6px">${fmtCur(totalComm)}</td>
          <td style="padding:6px"></td>
        </tr></tbody>
      </table>`;
    this._exportPDF(div, 'Rapport_Commissions_'+S.settings.company);
  },
  exportPipeline(){
    const div=document.createElement('div');
    div.style.cssText='padding:1.5rem;font-family:Plus Jakarta Sans,sans-serif;font-size:12px;color:#1e293b';
    const deals=filterByPeriod(S.deals);
    let html=this._generateHeader()+'<h3 style="margin-bottom:1rem">Rapport Pipeline Détaillé</h3>';
    Object.entries(S.stages).forEach(([k,v])=>{
      const sd=deals.filter(d=>d.stage==k);
      const total=sd.reduce((a,b)=>a+b.amount,0);
      html+=`<h4 style="margin:1rem 0 .5rem;color:${v.color}">${v.name} (${sd.length}) — ${fmtCur(total)}</h4>`;
      if(sd.length){
        html+=`<table style="width:100%;border-collapse:collapse;font-size:10px;margin-bottom:.5rem"><thead><tr style="background:#f1f5f9"><th style="padding:4px;text-align:left">Réf.</th><th style="padding:4px;text-align:left">Affaire</th><th style="padding:4px;text-align:left">Client</th><th style="padding:4px;text-align:right">Montant</th><th style="padding:4px;text-align:left">Commercial</th></tr></thead><tbody>`;
        sd.forEach(d=>{const c=getContact(d.contactId);const u=getUser(d.userId);
          html+=`<tr><td style="padding:3px">${d.ref||''}</td><td style="padding:3px">${d.name}</td><td style="padding:3px">${c?c.name:'—'}</td><td style="padding:3px;text-align:right;font-weight:700">${fmtCur(d.amount)}</td><td style="padding:3px">${u?u.name:'—'}</td></tr>`;
        });
        html+='</tbody></table>';
      }
    });
    div.innerHTML=html;
    this._exportPDF(div, 'Rapport_Pipeline_'+S.settings.company);
  },
  exportPerformance(){
    const div=document.createElement('div');
    div.style.cssText='padding:1.5rem;font-family:Plus Jakarta Sans,sans-serif;font-size:12px;color:#1e293b';
    const commercials=S.users.filter(u=>u.active!==false&&u.role!=='Lecture seule');
    const perf=commercials.map(u=>{
      const deals=filterByPeriod(S.deals).filter(d=>d.userId===u.id);
      const won=deals.filter(d=>d.stage===5);
      const ca=won.reduce((a,b)=>a+b.amount,0);
      const closed=deals.filter(d=>d.stage>=5).length;
      const conv=closed>0?Math.round(won.length/closed*100):0;
      const targetUser=getUserTarget(u);
      const atteinte=targetUser>0?Math.round(ca/targetUser*100):0;
      return {name:u.name, deals:deals.length, won:won.length, ca, conv, targetUser, atteinte, rate:u.rate||0};
    }).sort((a,b)=>b.ca-a.ca);
    div.innerHTML=this._generateHeader()+`
      <h3 style="margin-bottom:1rem">Performance Individuelle — Objectifs individuels</h3>
      <table style="width:100%;border-collapse:collapse;font-size:10px">
        <thead><tr style="background:#0f172a;color:white">
          <th style="padding:6px;text-align:left">Rang</th>
          <th style="padding:6px;text-align:left">Commercial</th>
          <th style="padding:6px;text-align:left">Objectif</th>
          <th style="padding:6px;text-align:left">CA Réalisé</th>
          <th style="padding:6px;text-align:left">Atteinte</th>
          <th style="padding:6px;text-align:left">Taux comm.</th>
          <th style="padding:6px;text-align:left">Gagnées</th>
          <th style="padding:6px;text-align:left">Conversion</th>
        </tr></thead>
        <tbody>${perf.map((p,i)=>`<tr style="background:${i%2?'#f8fafc':'white'}">
          <td style="padding:5px;font-weight:700">${i+1}</td>
          <td style="padding:5px">${p.name}</td>
          <td style="padding:5px">${fmtCur(p.targetUser)}</td>
          <td style="padding:5px;font-weight:700">${fmtCur(p.ca)}</td>
          <td style="padding:5px">${p.atteinte}%</td>
          <td style="padding:5px">${p.rate}%</td>
          <td style="padding:5px">${p.won}</td>
          <td style="padding:5px">${p.conv}%</td>
        </tr>`).join('')}</tbody>
      </table>`;
    this._exportPDF(div, 'Performance_'+S.settings.company);
  },
  exportForecast(){
    const div=document.createElement('div');
    div.style.cssText='padding:1.5rem;font-family:Plus Jakarta Sans,sans-serif;font-size:12px;color:#1e293b';
    const activeDeals=S.deals.filter(d=>d.stage>0&&d.stage<5);
    const forecast=activeDeals.reduce((a,b)=>a+(b.amount*getStageProb(b.stage)/100),0);
    const realized=filterByPeriod(S.deals).filter(d=>d.stage===5).reduce((a,b)=>a+b.amount,0);
    div.innerHTML=this._generateHeader()+`
      <h3 style="margin-bottom:1rem">Prévisionnel (Forecast)</h3>
      <table style="width:100%;margin-bottom:1.5rem"><tr>
        <td style="padding:1rem;background:#dbeafe;border-radius:8px;text-align:center"><strong>CA Déjà Réalisé</strong><br><span style="font-size:1.3rem;font-weight:800;color:#059669">${fmtCur(realized)}</span></td>
        <td style="padding:1rem;background:#ede9fe;border-radius:8px;text-align:center"><strong>Forecast Pipeline</strong><br><span style="font-size:1.3rem;font-weight:800;color:#7c3aed">${fmtCur(Math.round(forecast))}</span></td>
        <td style="padding:1rem;background:#d1fae5;border-radius:8px;text-align:center"><strong>Total Projeté</strong><br><span style="font-size:1.3rem;font-weight:800;color:#059669">${fmtCur(Math.round(realized+forecast))}</span></td>
      </tr></table>
      <h4 style="margin-bottom:.5rem">Détail du pipeline actif</h4>
      <table style="width:100%;border-collapse:collapse;font-size:10px">
        <thead><tr style="background:#0f172a;color:white"><th style="padding:6px;text-align:left">Affaire</th><th style="padding:6px;text-align:left">Client</th><th style="padding:6px;text-align:right">Montant</th><th style="padding:6px;text-align:left">Étape</th><th style="padding:6px;text-align:right">Prob.</th><th style="padding:6px;text-align:right">Pondéré</th></tr></thead>
        <tbody>${activeDeals.sort((a,b)=>b.amount-a.amount).map((d,i)=>{const c=getContact(d.contactId);return`<tr style="background:${i%2?'#f8fafc':'white'}"><td style="padding:5px">${d.name}</td><td style="padding:5px">${c?c.name:'—'}</td><td style="padding:5px;text-align:right;font-weight:700">${fmtCur(d.amount)}</td><td style="padding:5px">${getStageName(d.stage)}</td><td style="padding:5px;text-align:right">${getStageProb(d.stage)}%</td><td style="padding:5px;text-align:right;font-weight:700;color:#7c3aed">${fmtCur(Math.round(d.amount*getStageProb(d.stage)/100))}</td></tr>`}).join('')}
        <tr style="background:#0f172a;color:white;font-weight:700"><td style="padding:6px" colspan="2">TOTAL FORECAST</td><td style="padding:6px;text-align:right">${fmtCur(activeDeals.reduce((a,b)=>a+b.amount,0))}</td><td style="padding:6px" colspan="2"></td><td style="padding:6px;text-align:right">${fmtCur(Math.round(forecast))}</td></tr>
        </tbody></table>`;
    this._exportPDF(div, 'Forecast_'+S.settings.company);
  }
};

/* ═══════════════════════════════════════════════
   APP CONTROLLER
   ═══════════════════════════════════════════════ */
const App = {
  init(){
    buildPeriodFilter();
    Nav.init();
    this.refreshAll();
  },
  refreshAll(){
    Dashboard.render();
    Pipeline.render();
    Contacts.render();
    Commissions.render();
    Admin.render();
  },
  exportJSON(){
    const blob=new Blob([JSON.stringify(S,null,2)],{type:'application/json'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url;a.download='CRM_Backup_'+S.settings.company.replace(/\s/g,'_')+'_'+new Date().toISOString().split('T')[0]+'.json';
    a.click();URL.revokeObjectURL(url);
    addAudit('Export données JSON');save();
    Toast.show('Sauvegarde JSON téléchargée');
  },
  importJSON(event){
    const file=event.target.files[0];if(!file)return;
    if(!confirm('ATTENTION : Cette opération remplacera toutes les données actuelles. Continuer ?'))return;
    const reader=new FileReader();
    reader.onload=e=>{
      try{
        const data=JSON.parse(e.target.result);
        if(!data.settings||!data.users||!data.deals){throw new Error('Format invalide');}
        Object.assign(S,data);
        save();addAudit('Import données JSON',file.name);
        App.refreshAll();Toast.show('Données importées avec succès');
      }catch(err){Toast.show('Erreur: fichier invalide — '+err.message,'error');}
    };
    reader.readAsText(file);
  }
};
</script>
