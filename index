    if(!u||!confirm('Supprimer l\'utilisateur '+u.name+' ?'))return;
    S.users=S.users.filter(x=>x.id!==id);
    addAudit('Suppression utilisateur', u.name); save(); App.refreshAll(); Toast.show('Utilisateur supprimé');
