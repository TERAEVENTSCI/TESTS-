<script>
/* ═══════════════════════════════════════════════
   DATA LAYER
   ═══════════════════════════════════════════════ */
const DB_KEY = 'crm_dc_v2';
const DEFAULT_STAGES = {
  1:{name:'Prospection',prob:10,color:'#94a3b8'},
  2:{name:'Qualification',prob:25,color:'#6366f1'},
  3:{name:'Proposition / Devis',prob:50,color:'#f59e0b'},
  4:{name:'Négociation',prob:75,color:'#8b5cf6'},
  5:{name:'Clos – Gagné',prob:100,color:'#059669'},
  6:{name:'Clos – Perdu',prob:0,color:'#dc2626'}
};

function hashPassword(p){
  let h=0;for(let i=0;i<p.length;i++){h=((h<<5)-h)+p.charCodeAt(i);h|=0}return 'h_'+Math.abs(h).toString(36);
}

function defaultState(){
  return {
    settings:{company:'Mon Entreprise',currency:'FCFA',target:7000000,annualTarget:84000000,
      commMode:'flat',commTrigger:'signed',bonusRate:2,tiers:[{min:0,max:10000000,rate:5},{min:10000000,max:Infinity,rate:7}]},
    stages:JSON.parse(JSON.stringify(DEFAULT_STAGES)),
    users:[{id:1,name:'Administrateur',login:'admin',role:'Super Admin',rate:5,target:0,team:'Direction',active:true,pass:hashPassword('Admin@2026')}],
    contacts:[],
    deals:[],
    audit:[],
    commissions:{}
  };
}

let S = JSON.parse(localStorage.getItem(DB_KEY)) || defaultState();
let currentUser = null;
let chartPipeline = null, chartMonthly = null;

function save(){
  try{localStorage.setItem(DB_KEY, JSON.stringify(S));}catch(e){Toast.show('Erreur de sauvegarde: espace insuffisant','error');}
}

function addAudit(action, details=''){
  S.audit.unshift({date:new Date().toISOString(), user:currentUser?currentUser.name:'Système', action, details});
  if(S.audit.length>200) S.audit = S.audit.slice(0,200);
}

function fmt(n){
  if(!n&&n!==0) return '0';
  return Number(n).toLocaleString('fr-FR');
}
function fmtCur(n){return fmt(n)+' '+S.settings.currency}

function getContact(id){return S.contacts.find(c=>c.id===id)}
function getUser(id){return S.users.find(u=>u.id===id)}
function getStageName(s){return(S.stages[s]||{name:'?'}).name}
function getStageColor(s){return(S.stages[s]||{color:'#ccc'}).color}
function getStageProb(s){return(S.stages[s]||{prob:0}).prob}

/* ─── Calcul de l'objectif individuel d'un utilisateur ─── */
function getUserTarget(u){
  /* Priorité 1 : objectif défini explicitement sur la fiche utilisateur */
  if(u.target && u.target > 0) return u.target;
  /* Priorité 2 : fallback = objectif global divisé par le nombre de commerciaux actifs */
  const actifs = S.users.filter(x => x.active !== false && x.role !== 'Lecture seule');
  return S.settings.target / (actifs.length || 1);
}

